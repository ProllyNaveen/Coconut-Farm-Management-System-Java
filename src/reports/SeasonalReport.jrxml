<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport name="SeasonalReport" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6d275eaa-98f0-4cf2-915a-b20086f83fd4">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter"/>
	<parameter name="SEASON_ID" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT 
    u.full_name AS farmer_name,
    p.plot_name,
    p.tree_count,
    SUM(h.nut_count) AS total_nuts,
    COUNT(DISTINCT i.inspection_id) AS total_inspections,
    s.season_name
FROM plot p
JOIN user u ON p.farmer_id = u.user_id
JOIN harvest h ON h.plot_id = p.plot_id
JOIN inspection i ON i.plot_id = p.plot_id
JOIN season s ON h.season_id = s.season_id
WHERE s.season_id = $P{SEASON_ID}
GROUP BY p.plot_id, u.full_name, p.plot_name, p.tree_count, s.season_name]]></query>
	<field name="farmer_name" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="full_name"/>
		<property name="com.jaspersoft.studio.field.label" value="farmer_name"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="user"/>
	</field>
	<field name="plot_name" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="plot_name"/>
		<property name="com.jaspersoft.studio.field.label" value="plot_name"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="plot"/>
	</field>
	<field name="tree_count" class="java.lang.Integer">
		<property name="com.jaspersoft.studio.field.name" value="tree_count"/>
		<property name="com.jaspersoft.studio.field.label" value="tree_count"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="plot"/>
	</field>
	<field name="total_nuts" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="total_nuts"/>
		<property name="com.jaspersoft.studio.field.label" value="total_nuts"/>
	</field>
	<field name="total_inspections" class="java.lang.Long">
		<property name="com.jaspersoft.studio.field.name" value="total_inspections"/>
		<property name="com.jaspersoft.studio.field.label" value="total_inspections"/>
	</field>
	<field name="season_name" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="season_name"/>
		<property name="com.jaspersoft.studio.field.label" value="season_name"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="season"/>
	</field>
